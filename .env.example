# Kimi（Moonshot）配置
LLM_PROVIDER=kimi
MOONSHOT_API_KEY=your_kimi_api_key_here
KIMI_MODEL_ID=kimi-k2-turbo-preview
KIMI_BASE_URL=https://api.moonshot.cn/v1

# RAG 向量化方式（可选）：local（默认）| openai；Kimi 无 Embedding API
# REPO_AGENT_EMBEDDING=openai   # 需配置 OPENAI_API_KEY

# Agent 服务（远程 CLI/TUI）配置
AGENTD_HOST=127.0.0.1
AGENTD_PORT=8765
# 可选：为空表示不启用鉴权
AGENTD_TOKEN=

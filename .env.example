# Kimi（Moonshot）配置
LLM_PROVIDER=kimi
MOONSHOT_API_KEY=your_kimi_api_key_here
KIMI_MODEL_ID=kimi-k2-turbo-preview
KIMI_BASE_URL=https://api.moonshot.cn/v1

# RAG 向量化方式（可选）：local（默认）| kimi | openai
# kimi：使用 Moonshot-v1-embedding，复用上面的 MOONSHOT_API_KEY，无需额外 key
# openai：使用 OpenAI Embedding，需单独配置 OPENAI_API_KEY
# REPO_AGENT_EMBEDDING=kimi
# REPO_AGENT_EMBEDDING=openai

# Agent 服务（远程 CLI/TUI）配置
AGENTD_HOST=127.0.0.1
AGENTD_PORT=8765
# 可选：为空表示不启用鉴权
AGENTD_TOKEN=
